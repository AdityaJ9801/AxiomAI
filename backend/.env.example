# Economic Analysis Backend API Configuration

# Server Configuration
DEBUG=True
API_HOST=0.0.0.0
API_PORT=8000

# CORS Configuration (comma-separated list)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# File Upload Configuration
MAX_FILE_SIZE=104857600  # 100MB in bytes
ALLOWED_EXTENSIONS=csv,xlsx,xls,json

# Processing Limits
MAX_DATASET_ROWS=1000000
MAX_ANALYSIS_TIME=300  # seconds

# Performance Configuration
WORKERS=4
MAX_REQUESTS=1000
TIMEOUT=300

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/api.log

# Optional: Database Configuration (if using database)
# DATABASE_URL=postgresql://user:password@localhost:5432/economic_analysis

# Optional: Redis Configuration (for caching)
# REDIS_URL=redis://localhost:6379/0

# Optional: External API Keys
# OPENAI_API_KEY=your_openai_key_here
# OLLAMA_BASE_URL=http://localhost:11434

# Optional: Monitoring
# SENTRY_DSN=your_sentry_dsn_here