{
    "jsc": {
        "parser": {
            "syntax": "typescript",
            "tsx": true,
            "decorators": false,
            "dynamicImport": true
        },
        "transform": {
            "react": {
                "runtime": "automatic"
            }
        },
        "target": "es2017",
        "loose": false,
        "externalHelpers": true
    },
    "module": {
        "type": "es6"
    },
    "minify": false,
    "sourceMaps": true
}