# Production Environment Configuration for AXIOM AI
# Copy this file to .env and update values for your deployment

# ── Server Configuration ────────────────────────────────────────
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=3000
BACKEND_PORT=8000

# ── CORS Configuration ─────────────────────────────────────────
# Update with your production domain
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com,https://www.yourdomain.com

# ── API Configuration ──────────────────────────────────────────
# Update with your production API URL
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# ── File Upload Configuration ──────────────────────────────────
MAX_FILE_SIZE=104857600  # 100MB in bytes
ALLOWED_EXTENSIONS=csv,xlsx,xls,json

# ── Processing Limits ──────────────────────────────────────────
MAX_DATASET_ROWS=1000000
MAX_ANALYSIS_TIME=300  # seconds

# ── Performance Configuration ──────────────────────────────────
WORKERS=2
MAX_REQUESTS=1000
TIMEOUT=300

# ── Logging Configuration ──────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/api.log

# ── Data Storage ───────────────────────────────────────────────
DATA_PATH=./data

# ── SSL Configuration (for production with nginx) ──────────────
HTTP_PORT=80
HTTPS_PORT=443

# ── Optional: Database Configuration ───────────────────────────
# Uncomment and configure if using database
# DATABASE_URL=postgresql://user:password@localhost:5432/axiom_ai

# ── Optional: Redis Configuration ──────────────────────────────
# Uncomment and configure if using Redis for caching
# REDIS_URL=redis://localhost:6379/0

# ── Optional: External API Keys ────────────────────────────────
# Uncomment and add your API keys if needed
# OPENAI_API_KEY=your_openai_key_here
# OLLAMA_BASE_URL=http://localhost:11434

# ── Optional: Monitoring ───────────────────────────────────────
# Uncomment and configure if using monitoring services
# SENTRY_DSN=your_sentry_dsn_here
# PROMETHEUS_PORT=9090